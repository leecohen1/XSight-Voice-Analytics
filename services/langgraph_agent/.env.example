# langgraph_agent — environment variables
# Phase 6 mock skeleton requires no API keys and downloads no models.
# Variables below are placeholders for the real implementation (Phase 14).

PORT=8004

# Placeholder for Phase 14 — LLM backend for the Planner/Synthesizer nodes
