# guardrails_service — environment variables
# Phase 6 mock skeleton requires no API keys and downloads no models.
# Variables below are placeholders for the real implementation (Phase 11).

PORT=8003

# Placeholder for Phase 11 (NeMo Guardrails config directory, not used yet).
NEMO_CONFIG_DIR=./nemo_config

# Deterministic-rule thresholds already used by the Phase 6 mock rules.
MAX_FILE_SIZE_BYTES=104857600
MAX_DURATION_SECONDS=1800
MIN_TRANSCRIPT_LENGTH=20
OUTPUT_CONFIDENCE_HUMAN_REVIEW_THRESHOLD=0.65
