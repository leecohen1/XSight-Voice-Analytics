# rag_service — environment variables
# Phase 6 mock skeleton requires no API keys and downloads no models.
# Variables below are placeholders for the real implementation (Phase 12).

# Port the service listens on (also set in docker-compose.yml and the Dockerfile).
PORT=8001

# Path to the RAG corpus CSV, relative to the service's working directory.
# Not read in Phase 6 — only its existence is optionally logged at startup.
HISTORICAL_CALLS_CSV_PATH=../../data/historical_sales_calls.csv

# Placeholder for Phase 12 (ChromaDB persistence directory, not used yet).
CHROMA_PERSIST_DIR=./chroma_data
